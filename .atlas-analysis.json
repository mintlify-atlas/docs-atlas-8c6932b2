  "keyFeatures": [
    "JWT-based authentication with Spring Security",
    "Complete CRUD operations for portfolio entities (profile, experience, education, projects, skills, certificates)",
    "Google Drive integration for file uploads (avatars, resumes, project covers, skill icons)",
    "Public API for viewing portfolios without authentication",
    "Email notifications via SMTP",
    "MySQL database with Flyway migrations",
    "RESTful API design with comprehensive validation",
    "Docker support for containerized deployment"
  ],
  "publicApiSurface": [
    "POST /api/auth/register - Register new user",
    "POST /api/auth/login - Login and get JWT token",
    "GET /api/me/profile - Get authenticated user's profile",
    "PUT /api/me/profile - Update profile",
    "GET /api/me/experience - Get user experiences",
    "POST /api/me/experience - Create experience entry",
    "GET /api/me/education - Get user education",
    "POST /api/me/education - Create education entry",
    "GET /api/me/certificates - Get user certificates",
    "POST /api/me/certificates - Create certificate",
    "GET /api/me/projects - Get user projects",
    "POST /api/me/projects - Create project",
    "GET /api/me/skills - Get user skills and categories",
    "POST /api/me/skills/batch - Create multiple skills",
    "GET /api/me/social-links - Get user social links",
    "POST /api/me/social-links - Create social link",
    "POST /api/me/upload/* - Upload files to Google Drive",
    "GET /api/portfolios - List all public portfolios",
    "GET /api/portfolios/{slug} - Get portfolio by slug",
    "GET /api/portfolios/{profileSlug}/projects/{projectSlug} - Get project details",
    "POST /api/portfolios/{slug}/contact - Send contact message",
    "POST /api/admin/profiles/{profileId}/toggle-collaborator - Toggle collaborator status"
  ]
}
